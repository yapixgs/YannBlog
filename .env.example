# ── Application ───────────────────────────────────────────
APP_NAME=DevLog
ENVIRONMENT=development
SECRET_KEY=changez-moi-en-production-min-32-caracteres!!
DEBUG=false

# ── Base de données ───────────────────────────────────────
# Développement (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./blog.db
# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/devlog

# ── WebAuthn / YubiKey ────────────────────────────────────
# DOIT correspondre exactement au domaine utilisé dans le navigateur
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=DevLog Blog
WEBAUTHN_ORIGIN=http://localhost:8000
# En production :
# WEBAUTHN_RP_ID=mondomaine.fr
# WEBAUTHN_ORIGIN=https://mondomaine.fr

# ── Sécurité admin ────────────────────────────────────────
# Clé secrète requise pour créer un compte admin (YubiKey ou mot de passe)
# CHANGEZ cette valeur avant tout déploiement !
ADMIN_KEY=changez-moi-cle-admin-secrete

# ── Redis (optionnel, pour les sessions en prod) ──────────
REDIS_URL=redis://localhost:6379/0

# ── Serveur ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=INFO
